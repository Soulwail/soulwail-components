{
    "compilerOptions": {
        "baseUrl": "./",
        "target": "esnext",
        "module": "ESNext",
        "moduleResolution": "node",
        "jsx": "react-jsx",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "paths": {
            "@safety/react-grid-layout": ["../../packages/react-grid-layout/src/index.ts"]
        }
    },
    "include": ["./src"]
}
