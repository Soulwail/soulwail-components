{
    "name": "soulwail-components",
    "version": "0.0.1",
    "description": "自建组件库",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "start": "npm run dev",
        "dev": "npm run version && dumi dev",
        "build": "npm run version && npm run build-components",
        "build-components": "pnpm --filter \"@soulwail/**\" build",
        "docs:build": "dumi build",
        "docs:preview": "dumi preview",
        "prepare": "husky install && dumi setup",
        "doctor": "father doctor",
        "lint": "eslint --cache --ext .js,.jsx,.ts,.tsx  --fix --format=pretty ./ && npm run tsc && npm run lint:prettier",
        "lint:prettier": "npm run prettier &&  git diff && prettier --version && prettier --check \"packages/**/**.{js,jsx,tsx,ts,less,md,json}\" --end-of-line auto",
        "prettier": "prettier --write \"**/**.{js,jsx,tsx,ts,less,md,yaml,json}\" --loglevel warn",
        "publish": "node ./scripts/release.js",
        "version": "node ./scripts/gen_version.js"
    },
    "authors": [],
    "license": "MIT",
    "workspaces": [
        "packages/*"
    ],
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "lint-staged": {
        "*.{md,json}": [
            "prettier --write --no-error-on-unmatched-pattern"
        ],
        "*.{css,less}": [
            "stylelint --fix",
            "prettier --write"
        ],
        "*.{js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --parser=typescript --write"
        ]
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "react": ">=16.9.0",
        "react-dom": ">=16.9.0"
    },
    "devDependencies": {
        "@ant-design/icons": "^5.6.1",
        "@commitlint/cli": "^17.1.2",
        "@commitlint/config-conventional": "^17.1.0",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "@umijs/fabric": "^4.0.1",
        "@umijs/lint": "^4.0.0",
        "@umijs/utils": "^4.4.6",
        "antd": "^5.24.2",
        "babel-plugin-antd-style": "^1.0.4",
        "babel-plugin-transform-remove-console": "^6.9.4",
        "dumi": "^2.4.13",
        "dumi-theme-antd-style": "^0.31.1",
        "eslint": "^8.23.0",
        "execa": "^5.1.1",
        "father": "^4.1.0",
        "husky": "^8.0.1",
        "inquirer": "^8.2.6",
        "lerna": "^8.2.0",
        "lint-staged": "^13.0.3",
        "prettier": "^2.7.1",
        "prettier-plugin-organize-imports": "^3.0.0",
        "prettier-plugin-packagejson": "^2.2.18",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "stylelint": "^14.9.1"
    }
}
